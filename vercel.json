{
  "framework": "vite",
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "node scripts/normalize-source-encoding.mjs && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/|assets/|favicon.ico|robots.txt|placeholder.svg).*)",
      "destination": "/index.html"
    }
  ]
}
